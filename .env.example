# Noyrax MCP Server — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.

# Embeddings provider (V-dimension / semantic search). Voyage AI is the default.
VOYAGE_API_KEY=

# Optional LLM providers (ADR generation, summaries, agents).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MCP server runtime (optional)
# NODE_ENV=production
# NOYRAX_MCP_DEBUG=1
